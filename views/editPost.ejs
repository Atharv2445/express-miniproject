<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>
        Edit your post :
    </h1>

    <form method="post" action="/posts/<%= user.id%>?_method=PATCH">
        <div class="post">
        <h3>Post id:<%= user.id%></h3>
        <h3>Post username:<%= user.username%></h3>

        <textarea name="content" id="content" cols="35" rows="12"><%= user.content%></textarea>
        <button class="btn-1">submit</button>
        </div>

    </form>
</body>
</html>