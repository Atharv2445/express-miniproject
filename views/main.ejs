<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>main</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="allpost">
    <h1>Quora Posts</h1>
    <% for(users of user){ %>
        <div class="post">
            <h3 class="user">@<%=users.username%> </h2>
                
             <h4 class="content"><%=users.content%> </h2>

            <a href="http://localhost:8080/posts/<%= users.id %>">See in detail.</a>    
            
            <a href="http://localhost:8080/posts/ <%= users.id%>/edit">Edit.</a> 
           
             <form method="post" action="/posts/<%= users.id %>?_method=DELETE">
                <button class="btn-1 ">delete</button>
             </form>
       
        </div>   
        
    <% }%>
    <br><br>
    <a href="http://localhost:8080/posts/new" class="Create" >Create New Post</a><br>
</div>
</body>
</html>